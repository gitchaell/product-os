---
import { languages } from '@/i18n/ui';
import { type LangCode } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import DocsSidebar from '@/components/common/DocsSidebar.astro';

export function getStaticPaths() {
	return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

interface Props {
	lang: LangCode;
}

const { lang } = Astro.params as Props;


---
<Layout
	title="Components Overview - Documentation"
	description="Explore our comprehensive library of primitives and blocks."
	lang={lang}
>
	<div class="container mx-auto flex w-full flex-col md:flex-row">
		<DocsSidebar lang={lang} currentPath={Astro.url.pathname} />
		<main class="flex-1 min-w-0 px-4 md:px-8 py-12 flex min-h-[calc(100vh-4rem)] flex-col max-w-4xl mx-auto">
			<Breadcrumb
				items={[
					{ label: 'Home', href: `/${lang}` },
					{ label: 'Docs', href: `/${lang}/docs` },
					{ label: 'Components' }
				]}
				class="mb-8"
			/>

			<h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4">Components Overview</h1>
			<p class="text-lg text-zinc-600 dark:text-zinc-400 mb-12">
				Explore our comprehensive collection of accessible and customizable components.
				Our components are divided into fundamental <strong class="text-zinc-900 dark:text-zinc-100 font-semibold">Primitives</strong> and more complex, ready-to-use <strong class="text-zinc-900 dark:text-zinc-100 font-semibold">Blocks</strong>.
			</p>

			<section class="mb-16">
				<div class="flex items-center gap-2 mb-6 border-b border-zinc-200 dark:border-zinc-800 pb-2">
					<h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100">Primitives</h2>
				</div>
				<p class="text-zinc-600 dark:text-zinc-400 mb-6">
					Core building blocks that form the foundation of our design system.
				</p>
				<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
					<a href={`/${lang}/docs/components/accordion`} class="group flex flex-col p-4 border border-zinc-200 dark:border-zinc-800 rounded-xl hover:border-zinc-300 dark:hover:border-zinc-700 bg-white dark:bg-zinc-900/50 hover:bg-zinc-50 dark:hover:bg-zinc-800/80 transition-all shadow-sm hover:shadow-md">
						<span class="font-medium text-sm text-zinc-900 dark:text-zinc-100 group-hover:text-zinc-700 dark:group-hover:text-zinc-300">Accordion</span>
					</a>
					<a href={`/${lang}/docs/components/alert`} class="group flex flex-col p-4 border border-zinc-200 dark:border-zinc-800 rounded-xl hover:border-zinc-300 dark:hover:border-zinc-700 bg-white dark:bg-zinc-900/50 hover:bg-zinc-50 dark:hover:bg-zinc-800/80 transition-all shadow-sm hover:shadow-md">
						<span class="font-medium text-sm text-zinc-900 dark:text-zinc-100 group-hover:text-zinc-700 dark:group-hover:text-zinc-300">Alert</span>
					</a>
					<a href={`/${lang}/docs/components/barchart`} class="group flex flex-col p-4 border border-zinc-200 dark:border-zinc-800 rounded-xl hover:border-zinc-300 dark:hover:border-zinc-700 bg-white dark:bg-zinc-900/50 hover:bg-zinc-50 dark:hover:bg-zinc-800/80 transition-all shadow-sm hover:shadow-md">
