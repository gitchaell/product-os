{
	"name": "astro-template",
	"type": "module",
	"version": "1.0.0",
	"author": {
		"email": "f.michaell.a.m@gmail.com",
		"name": "Michaell Alavedra",
		"url": "https://michaellalavedra.com"
	},
	"keywords": [
		"astro",
		"template"
	],
	"repository": {
		"url": "https://github.com/gitchaell/astro-template"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome check --write .",
		"check": "biome check .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@astrojs/mdx": "^5.0.0",
		"@astrojs/sitemap": "^3.7.1",
		"@astrojs/ts-plugin": "^1.10.7",
		"@cloudcannon/editable-regions": "^0.0.12",
		"@iconify-json/tabler": "^1.2.31",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"astro-icon": "^1.1.5",
		"clsx": "^2.1.1",
		"gsap": "^3.14.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.7",
		"@biomejs/biome": "^2.4.4",
		"@cloudcannon/configuration-types": "^0.0.53",
		"@commitlint/cli": "^19.7.1",
		"@commitlint/config-conventional": "^19.7.1",
		"@playwright/test": "^1.58.2",
		"@types/node": "^22.13.1",
		"astro": "^6.0.4",
		"lint-staged": "^15.4.3",
		"playwright": "^1.58.2",
		"semantic-release": "^25.0.3",
		"typescript": "^5.9.3",
		"vitest": "^3.0.5"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc,astro,css}": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
