---
import { languages } from '@/i18n/ui';
import { type LangCode } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';
import DocsSidebar from '@/components/common/DocsSidebar.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import ComponentAlias from '@/components/primitives/Accordion.astro';
import CodeSnippet from '@/components/primitives/CodeSnippet.astro';

export function getStaticPaths() {
	return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

interface Props {
	lang: LangCode;
}

const { lang } = Astro.params as Props;
---

<Layout
	title="Accordion - Documentation"
	description="Documentation for Accordion component"
	lang={lang}
>
	<div class="container mx-auto flex w-full flex-col md:flex-row">
		<DocsSidebar lang={lang} currentPath={Astro.url.pathname} />
		<main class="flex-1 min-w-0 px-4 md:px-8 py-12 flex min-h-[calc(100vh-4rem)] flex-col max-w-4xl mx-auto">
		<Breadcrumb
			items={[
				{ label: 'Home', href: `/${lang}` },
				{ label: 'Docs', href: `/${lang}/docs` },
				{ label: 'Components', href: `/${lang}/docs/components` },
				{ label: 'Accordion' }
			]}
			class="mb-8"
		/>

		<h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4">Accordion</h1>
		<p class="text-lg text-zinc-600 dark:text-zinc-400 mb-8">
			A vertically stacked set of interactive headings that each reveal a section of content.
		</p>

		<section class="mb-12">
			<h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">Example Usage</h2>
			<div class="p-6 border border-zinc-200 dark:border-zinc-800 rounded-lg mb-8 bg-white dark:bg-zinc-900">
				<ComponentAlias items={[
                    {
                        title: "Is it accessible?",
                        content: "Yes. It adheres to the WAI-ARIA design pattern."
                    },
                    {
                        title: "Is it styled?",
                        content: "Yes. It comes with default styles that match the other components' aesthetic."
                    },
                    {
                        title: "Is it animated?",
                        content: "Yes. It's animated by default, but you can disable it if you prefer."
                    }
                ]} />
			</div>
            <CodeSnippet
                code={`<Accordion
  items={[
    {
      title: "Is it accessible?",
      content: "Yes. It adheres to the WAI-ARIA design pattern."
    },
    {
      title: "Is it styled?",
      content: "Yes. It comes with default styles that match the other components' aesthetic."
    },
    {
      title: "Is it animated?",
      content: "Yes. It's animated by default, but you can disable it if you prefer."
    }
  ]}
/>`}
                language="astro"
                filename="Example.astro"
            />
		</section>

        <section class="mb-12">
            <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">How to Use</h2>
            <p class="text-zinc-600 dark:text-zinc-400 mb-4">
                To use the Accordion component, import it from its location and pass the required props.
            </p>
            <CodeSnippet
                code={`import Accordion from '@/components/primitives/Accordion.astro';

const faqs = [
  { title: "Question 1", content: "Answer 1" },
  { title: "Question 2", content: "Answer 2" }
];

<Accordion items={faqs} />`}
                language="astro"
                filename="example.astro"
            />
        </section>
	</main>
	</div>
</Layout>