---
import "@/styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Product OS</title>
	</head>
	<body
		class="bg-gray-950 text-white flex flex-col items-center justify-center min-h-screen"
	>
		<h1 class="text-4xl font-bold mb-4" data-editable="source" data-path="/src/pages/index.astro" data-key="title">Welcome to Product OS</h1>
		<p class="text-lg text-gray-400" data-editable="source" data-path="/src/pages/index.astro" data-key="description">
			This is a starter template for your Astro project.
		</p>
	</body>
</html>
