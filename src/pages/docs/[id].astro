---
import { eq } from 'drizzle-orm';
import { marked } from 'marked';
import { db } from '../../db';
import { docEntries, products } from '../../db/schema';
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

if (!id) {
	return Astro.redirect('/404');
}

const entries = await db
	.select({
		id: docEntries.id,
		title: docEntries.title,
		description: docEntries.description,
		category: docEntries.category,
		author: docEntries.author,
		updatedAt: docEntries.updatedAt,
		content: docEntries.content,
		productName: products.name,
		featuredImage: docEntries.featuredImage,
	})
	.from(docEntries)
	.leftJoin(products, eq(docEntries.productId, products.id))
	.where(eq(docEntries.id, id));

const entry = entries[0];

if (!entry) {
	return Astro.redirect('/404');
}

const { title, description, category, author, productName, featuredImage } =
	entry;

const htmlContent = marked.parse(entry.content);
---

<Layout title={`${title} - Documentation | Product OS Hub`}>
	<div class="flex flex-col flex-1 px-6 py-8 max-w-[800px] mx-auto w-full">
		<a href="/docs" class="text-primary hover:text-primary/80 mb-6 inline-flex items-center gap-2">
			&larr; Back to Documentation
		</a>

		<article class="prose dark:prose-invert prose-slate max-w-none">
			<header class="mb-8 border-b border-slate-200 dark:border-slate-800 pb-8">
				<div class="flex items-center gap-4 mb-4">
					<span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border border-primary/20">
						{category}
					</span>
          {productName && (
            <span class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border border-slate-200 dark:border-slate-700">
              {productName}
            </span>
          )}
				</div>
				<h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-slate-100 font-display mb-4">{title}</h1>
				<p class="text-xl text-slate-600 dark:text-slate-400 mb-4">{description}</p>
				{author && <p class="text-slate-500 dark:text-slate-500 text-sm">By {author}</p>}
			</header>

			{featuredImage && (
				<div class="rounded-xl overflow-hidden mb-8 border border-slate-200 dark:border-slate-800">
					<img src={featuredImage} alt={title} class="w-full h-auto object-cover aspect-video" />
				</div>
			)}

			<div class="text-slate-700 dark:text-slate-300 leading-relaxed pt-6 prose lg:prose-lg dark:prose-invert">
				<div set:html={htmlContent} />
			</div>
		</article>
	</div>
</Layout>
