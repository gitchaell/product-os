---
import { tv, type VariantProps } from 'tailwind-variants';
import Icon from './Icon.astro';

const ratingVariants = tv({
	base: 'flex items-center gap-1',
	variants: {
		size: {
			sm: 'text-sm',
			md: 'text-base',
			lg: 'text-lg',
		},
	},
	defaultVariants: {
		size: 'md',
	},
});

const starVariants = tv({
	base: 'text-zinc-900 dark:text-white',
	variants: {
		filled: {
			true: 'fill-current',
			false: 'fill-transparent',
		},
		size: {
			sm: 'h-4 w-4',
			md: 'h-6 w-6',
			lg: 'h-8 w-8',
		},
	},
	defaultVariants: {
		filled: false,
		size: 'md',
	},
});

interface Props extends VariantProps<typeof ratingVariants> {
	class?: string;
	value?: number;
	max?: number;
	readonly?: boolean;
	name?: string;
}

const { class: className, size = 'md', value = 0, max = 5, readonly = false, name = 'rating' } = Astro.props;

const stars = Array.from({ length: max }, (_, i) => i + 1);
const containerId = `rating-${Math.random().toString(36).substring(2, 9)}`;
---

<div id={containerId} class={ratingVariants({ size, class: className })} data-rating={!readonly ? "true" : "false"} data-value={value}>
	<input type="hidden" name={name} value={value} />
	{stars.map((starValue) => {
		const filled = starValue < (value + 1);
		return (
			<button
				type="button"
				class={`focus:outline-none transition-transform hover:scale-110 ${readonly ? 'cursor-default pointer-events-none' : 'cursor-pointer'}`}
				data-star={starValue}
				aria-label={`Rate ${starValue} out of ${max}`}
				disabled={readonly}
			>
				<Icon
					name="Star"
					class={starVariants({ filled, size })}
					strokeWidth={filled ? 0 : 2}
					data-star-icon
				/>
			</button>
		);
	})}
</div>

{!readonly && (
	<script>
		const initRatings = () => {
			document.querySelectorAll('[data-rating="true"]').forEach(container => {
				const buttons = container.querySelectorAll('button[data-star]');
				const hiddenInput = container.querySelector('input[type="hidden"]') as HTMLInputElement;
				let currentValue = parseInt(container.getAttribute('data-value') || '0', 10);

				const updateStars = (val: number) => {
					buttons.forEach((btn, index) => {
						const icon = btn.querySelector('[data-star-icon]');
						if (!icon) return;
						const filled = index < val;

						if (filled) {
							icon.classList.add('fill-current');
							icon.classList.remove('fill-transparent');
							icon.setAttribute('stroke-width', '0');
						} else {
							icon.classList.remove('fill-current');
							icon.classList.add('fill-transparent');
							icon.setAttribute('stroke-width', '2');
						}
					});
				};

				buttons.forEach((btn) => {
					const val = parseInt(btn.getAttribute('data-star') || '0', 10);

					btn.addEventListener('mouseenter', () => updateStars(val));
					btn.addEventListener('mouseleave', () => updateStars(currentValue));

					btn.addEventListener('click', (e) => {
						e.preventDefault();
						currentValue = val;
						if (hiddenInput) {
							hiddenInput.value = val.toString();
							hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));
						}
						container.setAttribute('data-value', val.toString());
						updateStars(currentValue);
					});
				});
			});
		};

		document.addEventListener('astro:page-load', initRatings);
	</script>
)}
