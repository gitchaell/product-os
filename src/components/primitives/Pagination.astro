---
import { tv } from 'tailwind-variants';
import IconButton from './IconButton.astro';

const paginationVariants = tv({
	base: 'flex items-center justify-center gap-1 sm:gap-2',
});

interface Props {
	class?: string;
	currentPage?: number;
	totalPages?: number;
}

const {
	class: className,
	currentPage = 1,
	totalPages = 5,
	...rest
} = Astro.props;

// Helper to generate page numbers to show
const getPageNumbers = () => {
	const pages = [];
	for (let i = 1; i <= totalPages; i++) {
		// Simple logic to show first, last, current, and adjacent pages
		if (
			i === 1 ||
			i === totalPages ||
			(i >= currentPage - 1 && i <= currentPage + 1)
		) {
			pages.push(i);
		} else if (
			(i === currentPage - 2 && i > 1) ||
			(i === currentPage + 2 && i < totalPages)
		) {
			pages.push('...');
		}
	}
	// Deduplicate "..."
	return pages.filter((p, i, a) => p !== '...' || a[i - 1] !== '...');
};

const pagesToShow = getPageNumbers();
---

<nav class={paginationVariants({ class: className })} aria-label="Pagination" {...rest}>
	<IconButton
		icon="chevron-left"
		variant="outline"
		disabled={currentPage === 1}
		aria-label="Previous page"
	/>

	<div class="flex items-center gap-1 sm:gap-2">
		{
			pagesToShow.map((page) =>
				page === '...' ? (
					<span class="px-2 py-1 text-sm text-zinc-500 dark:text-zinc-400">...</span>
				) : (
					<button
						type="button"
						class={`flex h-10 min-w-[2.5rem] items-center justify-center rounded-lg px-2 text-sm font-medium transition-colors ${
							currentPage === page
								? 'bg-zinc-900 text-white dark:bg-zinc-100 dark:text-zinc-900'
								: 'text-zinc-600 hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800'
						}`}
						aria-current={currentPage === page ? 'page' : undefined}
					>
						{page}
					</button>
				),
			)
		}
	</div>

	<IconButton
		icon="chevron-right"
		variant="outline"
		disabled={currentPage === totalPages}
		aria-label="Next page"
	/>
</nav>
