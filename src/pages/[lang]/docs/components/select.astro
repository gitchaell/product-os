---
import { languages } from '@/i18n/ui';
import { type LangCode } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';
import DocsSidebar from '@/components/common/DocsSidebar.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import ComponentAlias from '@/components/primitives/Select.astro';
import CodeSnippet from '@/components/primitives/CodeSnippet.astro';

export function getStaticPaths() {
	return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

interface Props {
	lang: LangCode;
}

const { lang } = Astro.params as Props;
---

<Layout
	title="Select - Documentation"
	description="Documentation for Select component"
	lang={lang}
>
	<div class="container mx-auto flex w-full flex-col md:flex-row">
		<DocsSidebar lang={lang} currentPath={Astro.url.pathname} />
		<main class="flex-1 min-w-0 px-4 md:px-8 py-12 flex min-h-[calc(100vh-4rem)] flex-col max-w-4xl mx-auto">
		<Breadcrumb
			items={[
				{ label: 'Home', href: `/${lang}` },
				{ label: 'Docs', href: `/${lang}/docs` },
				{ label: 'Components', href: `/${lang}/docs/components` },
				{ label: 'Select' }
			]}
			class="mb-8"
		/>

		<h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4">Select</h1>
		<p class="text-lg text-zinc-600 dark:text-zinc-400 mb-8">
			The Select component allows users to choose one option from a list. It includes built-in styling for consistent design across browsers.
		</p>

		<section class="mb-12">
			<h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">Example Usage</h2>
			<div class="p-6 border border-zinc-200 dark:border-zinc-800 rounded-lg mb-8 bg-white dark:bg-zinc-900 max-w-sm">
				<ComponentAlias id="sel1" label="Favorite Framework" options={[
                    {label: "Astro", value: "astro"},
                    {label: "React", value: "react"},
                    {label: "Vue", value: "vue"},
                    {label: "Svelte", value: "svelte"}
                ]} />
			</div>
            <CodeSnippet
                code={`<Select
  id="framework"
  label="Favorite Framework"
  options={[
    {label: "Astro", value: "astro"},
    {label: "React", value: "react"},
    {label: "Vue", value: "vue"},
    {label: "Svelte", value: "svelte"}
  ]}
/>`}
                language="astro"
                filename="Example.astro"
            />
		</section>

        <section class="mb-12">
            <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">How to Use</h2>
            <p class="text-zinc-600 dark:text-zinc-400 mb-4">
                To use the Select component, import it from its location and pass the required props, specifically the options array.
            </p>
            <CodeSnippet
                code={`import Select from '@/components/primitives/Select.astro';

const options = [
  { label: 'Option 1', value: '1' },
  { label: 'Option 2', value: '2' },
];

<Select id="my-select" label="Choose an option" options={options} />`}
                language="astro"
                filename="example.astro"
            />
        </section>
	</main>
	</div>
</Layout>