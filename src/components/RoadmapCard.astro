---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'roadmap'>;
}

const { entry } = Astro.props;
const { data } = entry;
const { title, category, assignees = [], progress } = data;

// Simple color mapping per category
const categoryColors: Record<string, string> = {
	'UI/UX':
		'bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-400 border-slate-300 dark:border-slate-700',
	Analytics:
		'bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 border-indigo-500/20',
	AI: 'bg-purple-500/10 text-purple-600 dark:text-purple-400 border-purple-500/20',
	Security:
		'bg-amber-500/10 text-amber-600 dark:text-amber-500 border-amber-500/20',
	Infrastructure: 'bg-primary/10 text-primary border-primary/20',
	'Core API': 'bg-primary/10 text-primary border-primary/20',
	Webhooks:
		'bg-rose-500/10 text-rose-600 dark:text-rose-400 border-rose-500/20',
};

const categoryClasses =
	categoryColors[category] ||
	'bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-400 border-slate-300 dark:border-slate-700';
---

<!-- Roadmap Card -->
<a href={`/roadmap/${entry.id}`} class="block bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-primary/50 dark:hover:border-primary/50 hover:bg-slate-50/50 dark:hover:bg-slate-800/50 p-4 rounded-xl transition-all cursor-pointer text-inherit no-underline">
	<div class="flex justify-between items-start mb-3">
		<span class={`px-2 py-0.5 rounded-full text-[10px] border font-sans ${categoryClasses}`}>
			{category}
		</span>

		<!-- Assignees -->
		{assignees.length > 0 && (
			<div class="flex -space-x-2">
				{assignees.map((user) => (
					user.avatar ? (
						<img src={user.avatar} alt={user.name} class="w-5 h-5 rounded-full object-cover border border-white dark:border-background-dark" title={user.name} />
					) : (
						<div class="w-5 h-5 rounded-full bg-primary/20 dark:bg-primary/40 border border-white dark:border-background-dark text-[8px] flex items-center justify-center font-bold text-primary dark:text-slate-100" title={user.name}>
							{user.initials}
						</div>
					)
				))}
			</div>
		)}
	</div>

	<!-- Title -->
	<h4 class="text-sm font-medium text-slate-800 dark:text-slate-200 mb-4 leading-snug font-display">
		{title}
	</h4>

	<!-- Progress Bar (Only visible if progress > 0) -->
	{progress !== undefined && progress > 0 && (
		<div>
			<div class="flex items-center justify-between mb-1">
				<span class="text-[8px] text-slate-400 dark:text-slate-500 font-mono">PROGRESS</span>
				<span class="text-[8px] text-primary font-mono">{progress}%</span>
			</div>
			<div class="w-full bg-slate-200 dark:bg-slate-800 h-1 rounded-full overflow-hidden">
				<div class="bg-primary h-full shadow-[0_0_8px_var(--color-primary)] opacity-80" style={`width: ${progress}%`}></div>
			</div>
		</div>
	)}

	<!-- Empty State progress bar if no progress set or 0 -->
	{(progress === undefined || progress === 0) && (
		<div class="w-full bg-slate-200 dark:bg-slate-800 h-1 rounded-full overflow-hidden mt-4">
			<div class="bg-slate-300 dark:bg-slate-600 h-full w-0"></div>
		</div>
	)}

	<!-- Mock Approvals/Rejections -->
	<div class="flex items-center gap-3 mt-4 text-xs text-slate-500 dark:text-slate-400">
		<div class="flex items-center gap-1">
			<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
			<span>{Math.floor(Math.random() * 50) + 10}</span>
		</div>
		<div class="flex items-center gap-1">
			<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
			<span>{Math.floor(Math.random() * 10)}</span>
		</div>
	</div>
</a>
