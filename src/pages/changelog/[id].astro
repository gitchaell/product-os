---
import { eq } from 'drizzle-orm';
import { marked } from 'marked';
import { db } from '../../db';
import { changelogEntries, products } from '../../db/schema';
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

if (!id) {
	return Astro.redirect('/404');
}

const entries = await db
	.select({
		id: changelogEntries.id,
		title: changelogEntries.title,
		description: changelogEntries.description,
		version: changelogEntries.version,
		date: changelogEntries.date,
		type: changelogEntries.type,
		content: changelogEntries.content,
		productName: products.name,
	})
	.from(changelogEntries)
	.leftJoin(products, eq(changelogEntries.productId, products.id))
	.where(eq(changelogEntries.id, id));

const entry = entries[0];

if (!entry) {
	return Astro.redirect('/404');
}

const { title, version, date, type, productName, description } = entry;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const htmlContent = marked.parse(entry.content);
---

<Layout title={`${title} - Changelog | Product OS Hub`}>
	<div class="flex flex-col flex-1 px-6 py-8 max-w-[800px] mx-auto w-full">
		<a href="/changelog" class="text-primary hover:text-primary/80 mb-6 inline-flex items-center gap-2">
			&larr; Back to Changelog
		</a>

		<article class="prose dark:prose-invert prose-slate max-w-none">
			<header class="mb-8">
				<div class="flex items-center gap-4 mb-4">
					<span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border border-primary/20">
						{type}
					</span>
					<span class="text-slate-500 font-mono text-sm font-bold tracking-widest uppercase">{version}</span>
					<span class="text-slate-500 text-sm hidden sm:inline">&bull;</span>
					<span class="text-slate-500 text-sm font-medium">{formattedDate}</span>
          {productName && (
            <span class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border border-slate-200 dark:border-slate-700">
              {productName}
            </span>
          )}
				</div>
				<h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-slate-100 font-display mb-4">{title}</h1>
				{description && <p class="text-xl text-slate-600 dark:text-slate-400 mb-4">{description}</p>}
			</header>

			<div class="text-slate-700 dark:text-slate-300 leading-relaxed pt-6 border-t border-slate-200 dark:border-slate-800 prose lg:prose-lg dark:prose-invert">
				<div set:html={htmlContent} />
			</div>
		</article>
	</div>
</Layout>
