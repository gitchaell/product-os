---
import { Github, Twitter } from '@lucide/astro';
import Logo from '@/components/blocks/Logo.astro';
import { languages } from '@/i18n/ui';
import { type LangCode, useTranslations } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';

export function getStaticPaths() {
	return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

interface Props {
	lang: LangCode;
}

const { lang } = Astro.params as Props;

const t = useTranslations(lang);
---

<Layout
	title={t("login.title") as string}
	description={t("login.description") as string}
	lang={lang}
>
	<main
		class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center overflow-hidden py-12 px-4 sm:px-6 lg:px-8"
	>
		<!-- Background Elements -->
		<div
			class="absolute inset-0 z-0 flex items-center justify-center pointer-events-none"
		>
			<div
				class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-size[24px_24px] mask-[radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"
			>
			</div>
			<div
				class="absolute w-full h-full bg-zinc-50/10 dark:bg-zinc-950/10 backdrop-blur-[1px]"
			>
			</div>
			<div
				class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-125 h-125 bg-linear-to-tr from-zinc-300/20 to-transparent dark:from-zinc-800/20 blur-3xl rounded-full opacity-50"
			>
			</div>
		</div>

		<div class="relative z-10 w-full max-w-md px-4">
			<div class="mb-8 flex flex-col items-center text-center">
				<Logo size="xl" class="mb-6" />
				<h1
					class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100"
				>
					{t("login.heading") as string}
				</h1>
				<p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">
					Welcome back. Please enter your details.
				</p>
			</div>

			<div
				class="rounded-2xl border border-zinc-200 bg-white/50 p-6 sm:p-8 backdrop-blur-xl shadow-2xl dark:border-zinc-800 dark:bg-zinc-900/50"
			>
				<form class="space-y-4" onsubmit="return false;">
					<div class="space-y-1">
						<label
							for="email"
							class="text-sm font-medium text-zinc-900 dark:text-zinc-100"
						>
							{t("login.emailLabel") as string}
						</label>
						<input
							type="email"
							id="email"
							class="flex h-10 w-full rounded-md border border-zinc-200 bg-white px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:placeholder:text-zinc-400 dark:focus:ring-white dark:focus:ring-offset-zinc-950 transition-colors"
							placeholder="you@example.com"
							required
						/>
					</div>

					<div class="space-y-1">
						<label
							for="password"
							class="text-sm font-medium text-zinc-900 dark:text-zinc-100"
						>
							{t("login.passwordLabel") as string}
						</label>
						<input
							type="password"
							id="password"
							class="flex h-10 w-full rounded-md border border-zinc-200 bg-white px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:placeholder:text-zinc-400 dark:focus:ring-white dark:focus:ring-offset-zinc-950 transition-colors"
							placeholder="••••••••"
							required
						/>
					</div>

					<button
						type="submit"
						class="inline-flex h-10 w-full items-center justify-center rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-zinc-50 transition-colors hover:bg-zinc-900/90 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2 dark:bg-zinc-50 dark:text-zinc-900 dark:hover:bg-zinc-50/90 dark:focus:ring-zinc-50 dark:focus:ring-offset-zinc-950 mt-2"
					>
						{t("login.button") as string}
					</button>
				</form>

				<div class="relative mt-6 mb-6">
					<div class="absolute inset-0 flex items-center">
						<div class="w-full border-t border-zinc-200 dark:border-zinc-800">
						</div>
					</div>
					<div class="relative flex justify-center text-xs uppercase">
						<span
							class="bg-zinc-50 px-2 text-zinc-500 dark:bg-zinc-900/50 dark:text-zinc-400 backdrop-blur-xl"
							>Or continue with</span
						>
					</div>
				</div>

				<div class="grid grid-cols-2 gap-4">
					<button
						type="button"
						class="inline-flex h-10 w-full items-center justify-center gap-2 rounded-md border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-900 transition-colors hover:bg-zinc-100 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-800 dark:focus:ring-zinc-50 dark:focus:ring-offset-zinc-950"
					>
						<Github class="h-4 w-4" />
						GitHub
					</button>
					<button
						type="button"
						class="inline-flex h-10 w-full items-center justify-center gap-2 rounded-md border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-900 transition-colors hover:bg-zinc-100 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-800 dark:focus:ring-zinc-50 dark:focus:ring-offset-zinc-950"
					>
						<Twitter class="h-4 w-4" />
						Twitter
					</button>
				</div>

				<p class="mt-8 text-center text-sm text-zinc-500 dark:text-zinc-400">
					Don't have an account? <a
						href="#"
						class="font-medium text-zinc-900 underline underline-offset-4 hover:text-zinc-900/80 dark:text-zinc-100 dark:hover:text-zinc-100/80"
						>Sign up</a
					>
				</p>
			</div>
		</div>
	</main>
</Layout>
