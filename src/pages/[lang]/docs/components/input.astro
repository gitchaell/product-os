---
import { languages } from '@/i18n/ui';
import { type LangCode } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';
import DocsSidebar from '@/components/common/DocsSidebar.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import ComponentAlias from '@/components/primitives/Input.astro';
import CodeSnippet from '@/components/primitives/CodeSnippet.astro';

export function getStaticPaths() {
	return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

interface Props {
	lang: LangCode;
}

const { lang } = Astro.params as Props;
---

<Layout
	title="Input - Documentation"
	description="Documentation for Input component"
	lang={lang}
>
	<div class="container mx-auto flex w-full flex-col md:flex-row">
		<DocsSidebar lang={lang} currentPath={Astro.url.pathname} />
		<main class="flex-1 min-w-0 px-4 md:px-8 py-12 flex min-h-[calc(100vh-4rem)] flex-col max-w-4xl mx-auto">
		<Breadcrumb
			items={[
				{ label: 'Home', href: `/${lang}` },
				{ label: 'Docs', href: `/${lang}/docs` },
				{ label: 'Components', href: `/${lang}/docs/components` },
				{ label: 'Input' }
			]}
			class="mb-8"
		/>

		<h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4">Input</h1>
		<p class="text-lg text-zinc-600 dark:text-zinc-400 mb-8">
			The Input component is a form primitive for capturing user text input. It supports labels, errors, and standard HTML input attributes.
		</p>

		<section class="mb-12">
			<h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">Example Usage</h2>
			<div class="p-6 border border-zinc-200 dark:border-zinc-800 rounded-lg mb-8 bg-white dark:bg-zinc-900">
				<ComponentAlias id="inp1" label="Text Input" placeholder="Enter your text..." />
			</div>

            <h3 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4 mt-8">Input Types</h3>
            <p class="text-zinc-600 dark:text-zinc-400 mb-4">
                The component supports all standard input types like text, email, password, etc.
            </p>
            <div class="p-6 border border-zinc-200 dark:border-zinc-800 rounded-lg mb-8 bg-white dark:bg-zinc-900 flex flex-col gap-6 max-w-sm">
                <ComponentAlias id="inp-text" type="text" label="Username" placeholder="johndoe" />
                <ComponentAlias id="inp-email" type="email" label="Email Address" placeholder="john@example.com" />
                <ComponentAlias id="inp-password" type="password" label="Password" placeholder="••••••••" />
            </div>
            <CodeSnippet
                code={`<Input id="inp-text" type="text" label="Username" placeholder="johndoe" />
<Input id="inp-email" type="email" label="Email Address" placeholder="john@example.com" />
<Input id="inp-password" type="password" label="Password" placeholder="••••••••" />`}
                language="astro"
                filename="Types.astro"
            />

            <h3 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4 mt-12">States</h3>
            <p class="text-zinc-600 dark:text-zinc-400 mb-4">
                Inputs can display error messages or be disabled to prevent interaction.
            </p>
            <div class="p-6 border border-zinc-200 dark:border-zinc-800 rounded-lg mb-8 bg-white dark:bg-zinc-900 flex flex-col gap-6 max-w-sm">
                <ComponentAlias id="inp-error" label="Invalid Input" error="This field is required" />
                <ComponentAlias id="inp-disabled" label="Disabled Input" disabled placeholder="You cannot type here" />
            </div>
            <CodeSnippet
                code={`<Input id="inp-error" label="Invalid Input" error="This field is required" />
<Input id="inp-disabled" label="Disabled Input" disabled placeholder="You cannot type here" />`}
                language="astro"
                filename="States.astro"
            />
		</section>

        <section class="mb-12">
            <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">How to Use</h2>
            <p class="text-zinc-600 dark:text-zinc-400 mb-4">
                To use the Input component, import it from its location and pass the required props.
            </p>
            <CodeSnippet
                code={`import Input from '@/components/primitives/Input.astro';

<form action="/submit">
  <Input
    id="email"
    type="email"
    label="Email Address"
    placeholder="Enter your email"
    required
  />
</form>`}
                language="astro"
                filename="example.astro"
            />
        </section>
	</main>
	</div>
</Layout>