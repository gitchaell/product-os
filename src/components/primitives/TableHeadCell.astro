---
import { tv } from 'tailwind-variants';

const headCellVariants = tv({
	base: 'border-b border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-800/50 py-3 px-4 text-left text-xs font-semibold text-zinc-900 dark:text-zinc-100 align-middle',
});

interface Props {
	class?: string;
}

const { class: className, ...rest } = Astro.props;
---

<th class={headCellVariants({ class: className })} {...rest}>
	<slot />
</th>
