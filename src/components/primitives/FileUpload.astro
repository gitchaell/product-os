---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import Icon from './Icon.astro';

const fileUploadVariants = tv({
	base: 'relative flex flex-col items-center justify-center rounded-xl border border-[#D0D5DD] bg-[#F9FAFB] p-8 text-center transition-colors hover:bg-[#F2F4F7] focus:outline-none focus:ring-2 focus:ring-[#101828] focus:ring-offset-2 dark:border-[#344054] dark:bg-[#101828] dark:hover:bg-[#1D2939] dark:focus:ring-white dark:focus:ring-offset-zinc-950 cursor-pointer',
});

type FileUploadVariants = VariantProps<typeof fileUploadVariants>;

interface Props
	extends Omit<HTMLAttributes<'input'>, 'type'>,
		FileUploadVariants {
	label?: string;
	description?: string;
}

const {
	label = 'Click to upload or drag and drop',
	description = 'SVG, PNG, JPG or GIF (max. 800x400px)',
	class: className,
	id,
	...rest
} = Astro.props;

const inputId =
	id || `file-upload-${Math.random().toString(36).substring(2, 9)}`;
---

<label for={inputId} class={fileUploadVariants({ class: className })}>
	<div class="mb-4 rounded-lg bg-[#F2F4F7] p-2 dark:bg-[#1D2939]">
		<Icon name="Upload" class="h-6 w-6 text-[#101828] dark:text-white" />
	</div>
	<div class="space-y-1">
		<p class="text-sm font-semibold text-[#101828] dark:text-white">
			{label}
		</p>
		<p class="text-xs text-[#667085] dark:text-[#98A2B3]">
			{description}
		</p>
	</div>
	<input
		type="file"
		id={inputId}
		class="sr-only"
		{...rest}
	/>
</label>
