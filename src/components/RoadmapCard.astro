---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'roadmap'>;
}

const { entry } = Astro.props;
const { data } = entry;
const { title, category, assignees = [], progress } = data;

// Simple color mapping per category
const categoryColors: Record<string, string> = {
	'UI/UX': 'bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-400 border-slate-300 dark:border-slate-700',
	Analytics: 'bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 border-indigo-500/20',
	AI: 'bg-purple-500/10 text-purple-600 dark:text-purple-400 border-purple-500/20',
	Security: 'bg-amber-500/10 text-amber-600 dark:text-amber-500 border-amber-500/20',
	Infrastructure: 'bg-primary/10 text-primary border-primary/20',
	'Core API': 'bg-primary/10 text-primary border-primary/20',
	Webhooks: 'bg-rose-500/10 text-rose-600 dark:text-rose-400 border-rose-500/20',
};

const categoryClasses =
	categoryColors[category] || 'bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-400 border-slate-300 dark:border-slate-700';
---

<!--
  Roadmap Card - visually editable item inside a Roadmap column
-->
<a href={`/roadmap/${entry.id}`} class="block bg-white dark:bg-[rgba(255,255,255,0.02)] border border-slate-200 dark:border-[rgba(13,242,242,0.08)] hover:border-primary/50 dark:hover:border-primary/50 hover:bg-slate-50/50 dark:hover:bg-[rgba(255,255,255,0.04)] p-4 rounded-xl transition-all cursor-pointer text-inherit no-underline">
	<div class="flex justify-between items-start mb-3">
		<span class={`px-2 py-0.5 rounded-full text-[10px] border font-sans ${categoryClasses}`} data-editable="text" data-prop={`@collections[roadmap].${entry.id}.category`}>
			{category}
		</span>

		<!-- Assignees -->
		{assignees.length > 0 && (
			<div class="flex -space-x-2" data-editable="array" data-prop={`@collections[roadmap].${entry.id}.assignees`} data-direction="row">
				{assignees.map((user) => (
					<div class="w-5 h-5 rounded-full bg-primary/20 dark:bg-primary/40 border border-white dark:border-background-dark text-[8px] flex items-center justify-center font-bold text-primary dark:text-slate-100" data-editable="array-item" title={user.name}>
						{user.initials}
					</div>
				))}
			</div>
		)}
	</div>

	<!-- Title -->
	<h4 class="text-sm font-medium text-slate-800 dark:text-slate-200 mb-4 leading-snug font-display" data-editable="text" data-prop={`@collections[roadmap].${entry.id}.title`} data-type="span">
		{title}
	</h4>

	<!-- Progress Bar (Only visible if progress > 0) -->
	{progress !== undefined && progress > 0 && (
		<div>
			<div class="flex items-center justify-between mb-1">
				<span class="text-[8px] text-slate-400 dark:text-slate-500 font-mono">PROGRESS</span>
				<span class="text-[8px] text-primary font-mono">{progress}%</span>
			</div>
			<div class="w-full bg-slate-200 dark:bg-slate-800 h-1 rounded-full overflow-hidden">
				<div class="bg-primary h-full shadow-[0_0_8px_var(--color-primary)] opacity-80" style={`width: ${progress}%`}></div>
			</div>
		</div>
	)}

	<!-- Empty State progress bar if no progress set or 0 -->
	{(progress === undefined || progress === 0) && (
		<div class="w-full bg-slate-200 dark:bg-slate-800 h-1 rounded-full overflow-hidden mt-4">
			<div class="bg-slate-300 dark:bg-slate-600 h-full w-0"></div>
		</div>
	)}
</a>
