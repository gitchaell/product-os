---
import { tv } from 'tailwind-variants';

const chartVariants = tv({
	base: 'relative w-full rounded-xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-950',
});

interface Props {
	class?: string;
	title?: string;
	type?: 'line' | 'bar' | 'doughnut';
	// biome-ignore lint/suspicious/noExplicitAny: Required for Chart.js options typing fallback
	data: any;
	// biome-ignore lint/suspicious/noExplicitAny: Required for Chart.js options typing fallback
	options?: any;
	height?: number;
}

const {
	class: className,
	title,
	type = 'line',
	data,
	options = {},
	height = 300,
	...rest
} = Astro.props;

const id = `chart-${Math.random().toString(36).substring(2, 9)}`;

const defaultOptions = {
	responsive: true,
	maintainAspectRatio: false,
	plugins: {
		legend: {
			display: true,
			position: 'bottom',
			labels: {
				usePointStyle: true,
				boxWidth: 8,
			},
		},
		tooltip: {
			backgroundColor: 'rgba(24, 24, 27, 0.9)', // zinc-900
			titleColor: '#fff',
			bodyColor: '#e4e4e7', // zinc-200
			borderColor: 'rgba(63, 63, 70, 0.5)', // zinc-700
			borderWidth: 1,
			padding: 12,
			cornerRadius: 8,
		},
	},
	scales:
		type === 'doughnut'
			? {}
			: {
					x: {
						grid: {
							display: false,
						},
						border: {
							display: false,
						},
					},
					y: {
						border: {
							display: false,
						},
						grid: {
							color: 'rgba(161, 161, 170, 0.1)', // zinc-400 with opacity
						},
					},
				},
};

const finalOptions = { ...defaultOptions, ...options };
---

<div class={chartVariants({ class: className })} {...rest}>
	{title && <h3 class="mb-4 text-sm font-medium text-zinc-900 dark:text-zinc-100">{title}</h3>}

	<div style={`height: ${height}px; width: 100%;`}>
		<canvas
			id={id}
			data-type={type}
			data-chart={JSON.stringify(data)}
			data-options={JSON.stringify(finalOptions)}
		></canvas>
	</div>

	<script>
		// Use auto-registering Chart.js bundle via CDN to resolve rendering issues
		// @ts-ignore
		import Chart from 'https://cdn.jsdelivr.net/npm/chart.js@4.4.1/auto/+esm';

		const initCharts = () => {
			const canvases = document.querySelectorAll('canvas[id^="chart-"]');

			const isDark = document.documentElement.classList.contains('dark');
			const textColor = isDark ? '#a1a1aa' : '#71717a';
			const gridColor = isDark ? 'rgba(255, 255, 255, 0.05)' : 'rgba(0, 0, 0, 0.05)';
			const chartColors = isDark ? ['#a1a1aa', '#52525b', '#3f3f46'] : ['#3b82f6', '#10b981', '#f59e0b'];

			Chart.defaults.color = textColor;
			Chart.defaults.font.family = 'Inter, ui-sans-serif, system-ui, sans-serif';

			canvases.forEach(canvas => {
				const ctx = (canvas as HTMLCanvasElement).getContext('2d');
				if (!ctx) return;

				const chartInstance = Chart.getChart(canvas);
				if (chartInstance) {
					chartInstance.destroy();
				}

				const type = canvas.getAttribute('data-type');
				const data = JSON.parse(canvas.getAttribute('data-chart') || '{}');
				const options = JSON.parse(canvas.getAttribute('data-options') || '{}');

				if (options.scales?.x) {
					if (options.scales.x.ticks) options.scales.x.ticks.color = textColor;
					if (options.scales.x.grid) options.scales.x.grid.color = gridColor;
				}
				if (options.scales?.y) {
					if (options.scales.y.ticks) options.scales.y.ticks.color = textColor;
					if (options.scales.y.grid) options.scales.y.grid.color = gridColor;
				}

				if (data.datasets) {
					data.datasets.forEach((dataset: any, index: number) => {
						if (!dataset.backgroundColor || dataset.backgroundColor === '#71717a') {
							dataset.backgroundColor = type === 'doughnut' ? chartColors : chartColors[index % chartColors.length];
						}
						if (!dataset.borderColor || dataset.borderColor === '#71717a') {
							dataset.borderColor = type === 'doughnut' ? chartColors : chartColors[index % chartColors.length];
						}
					});
				}

				new Chart(ctx, {
					type,
					data,
					options
				});
			});
		};

		document.addEventListener('astro:page-load', initCharts);

		const observer = new MutationObserver((mutations) => {
			mutations.forEach((mutation) => {
				if (mutation.attributeName === 'class') {
					initCharts();
				}
			});
		});

		document.addEventListener('astro:page-load', () => {
			observer.observe(document.documentElement, { attributes: true });
		}, { once: true });
	</script>
</div>
