---
import { Icon } from 'astro-icon/components';
import Head from '@/components/common/Head.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';

import siteData from '@/data/site.json';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'The Product OS Hub' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <Head title={title} description={description} />
  <body class="bg-background-light dark:bg-background-dark font-sans text-slate-900 dark:text-slate-100 min-h-screen transition-colors duration-300">
    <div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden">
      <!-- Header common across screens -->
      <header class="sticky top-0 z-50 flex items-center justify-between border-b border-slate-200 dark:border-border-dark bg-white/80 dark:bg-background-dark/80 backdrop-blur-md px-6 md:px-20 py-4 transition-colors duration-300">
        <div class="flex items-center gap-8">
          <div class="flex items-center gap-3 text-primary" data-editable="source" data-path="/src/data/site.json">
            <img src={siteData.logo} alt="Logo" class="w-8 h-8" data-editable="image" data-prop-src="logo" />
            <h2 class="text-slate-900 dark:text-slate-100 text-lg font-bold leading-tight tracking-tight font-display" data-editable="text" data-prop="site_title">{siteData.site_title}</h2>
          </div>
          <nav class="hidden sm:flex items-center gap-4 md:gap-8">
            <a class="text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary text-sm font-medium transition-colors" href="/changelog">Changelog</a>
            <a class="text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary text-sm font-medium transition-colors" href="/roadmap">Roadmap</a>
            <a class="text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary text-sm font-medium transition-colors" href="/docs">Docs</a>
            <a class="text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary text-sm font-medium transition-colors" href="/feedback">Feedback</a>
          </nav>
        </div>

        <div class="flex items-center gap-4">
          <ThemeToggle />
          <!-- Mobile nav icon -->
          <button class="sm:hidden text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors focus:outline-none" aria-label="Menu" id="mobile-menu-btn">
            <Icon name="tabler:menu-2" class="w-6 h-6" />
          </button>
        </div>
      </header>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden sm:hidden bg-white/95 dark:bg-background-dark/95 backdrop-blur-md border-b border-slate-200 dark:border-border-dark px-6 py-4 fixed top-[65px] left-0 w-full z-40 flex flex-col gap-4">
        <a class="text-slate-700 dark:text-slate-300 hover:text-primary text-lg font-medium transition-colors" href="/changelog">Changelog</a>
        <a class="text-slate-700 dark:text-slate-300 hover:text-primary text-lg font-medium transition-colors" href="/roadmap">Roadmap</a>
        <a class="text-slate-700 dark:text-slate-300 hover:text-primary text-lg font-medium transition-colors" href="/docs">Docs</a>
        <a class="text-slate-700 dark:text-slate-300 hover:text-primary text-lg font-medium transition-colors" href="/feedback">Feedback</a>
      </div>

      <script>
        document.addEventListener('astro:page-load', () => {
          const btn = document.getElementById('mobile-menu-btn');
          const menu = document.getElementById('mobile-menu');

          if (btn && menu) {
            btn.addEventListener('click', () => {
              menu.classList.toggle('hidden');
            });
          }
        });
      </script>

      <main class="flex-1 w-full mx-auto">
        <slot />
      </main>

      <!-- Footer common across screens -->
      <footer class="mt-32 pt-12 border-t border-slate-200 dark:border-border-dark flex flex-col md:flex-row justify-between items-center gap-8 text-slate-500 text-sm px-6 pb-6 transition-colors duration-300">
        <div class="flex items-center gap-4">
          <span>© 2024 Product OS Hub</span>
          <span>•</span>
          <div class="flex gap-4" data-editable="source" data-path="/src/data/site.json">
            <div class="flex gap-4" data-editable="array" data-prop="social_links">
              {siteData.social_links.map((link: { name: string; url: string }) => (
                <a class="hover:text-primary" href={link.url}>{link.name}</a>
              ))}
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
