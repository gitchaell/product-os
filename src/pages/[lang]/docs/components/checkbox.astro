---
import { languages } from '@/i18n/ui';
import { type LangCode } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';
import DocsSidebar from '@/components/common/DocsSidebar.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import ComponentAlias from '@/components/primitives/Checkbox.astro';
import CodeSnippet from '@/components/primitives/CodeSnippet.astro';

export function getStaticPaths() {
	return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

interface Props {
	lang: LangCode;
}

const { lang } = Astro.params as Props;
---

<Layout
	title="Checkbox - Documentation"
	description="Documentation for Checkbox component"
	lang={lang}
>
	<div class="container mx-auto flex w-full flex-col md:flex-row">
		<DocsSidebar lang={lang} currentPath={Astro.url.pathname} />
		<main class="flex-1 min-w-0 px-4 md:px-8 py-12 flex min-h-[calc(100vh-4rem)] flex-col max-w-4xl mx-auto">
		<Breadcrumb
			items={[
				{ label: 'Home', href: `/${lang}` },
				{ label: 'Docs', href: `/${lang}/docs` },
				{ label: 'Components', href: `/${lang}/docs/components` },
				{ label: 'Checkbox' }
			]}
			class="mb-8"
		/>

		<h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4">Checkbox</h1>
		<p class="text-lg text-zinc-600 dark:text-zinc-400 mb-8">
			Checkboxes allow users to select one or more items from a set. Can be used to turn an option on or off.
		</p>

		<section class="mb-12">
			<h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">Example Usage</h2>
			<div class="p-6 border border-zinc-200 dark:border-zinc-800 rounded-lg mb-8 bg-white dark:bg-zinc-900 flex flex-col gap-4">
				<ComponentAlias id="chk1" label="Accept terms and conditions" />
                <ComponentAlias id="chk2" label="Subscribe to newsletter" checked />
			</div>
            <CodeSnippet
                code={`<Checkbox id="terms" label="Accept terms and conditions" />
<Checkbox id="newsletter" label="Subscribe to newsletter" checked />`}
                language="astro"
                filename="Example.astro"
            />

            <h3 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4 mt-12">States</h3>
            <p class="text-zinc-600 dark:text-zinc-400 mb-4">
                Checkboxes can have error states and disabled states.
            </p>
            <div class="p-6 border border-zinc-200 dark:border-zinc-800 rounded-lg mb-8 bg-white dark:bg-zinc-900 flex flex-col gap-6">
                <ComponentAlias id="chk-error" label="Required field" error="You must check this box" variant="error" />
                <ComponentAlias id="chk-disabled" label="Disabled unchecked" disabled />
                <ComponentAlias id="chk-disabled-checked" label="Disabled checked" checked disabled />
            </div>
            <CodeSnippet
                code={`<Checkbox
  id="required-chk"
  label="Required field"
  error="You must check this box"
  variant="error"
/>

<Checkbox id="chk-disabled" label="Disabled unchecked" disabled />
<Checkbox id="chk-disabled-checked" label="Disabled checked" checked disabled />`}
                language="astro"
                filename="States.astro"
            />
		</section>

        <section class="mb-12">
            <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">How to Use</h2>
            <p class="text-zinc-600 dark:text-zinc-400 mb-4">
                To use the Checkbox component, import it from its location and pass the required props.
            </p>
            <CodeSnippet
                code={`import Checkbox from '@/components/primitives/Checkbox.astro';

<form>
  <Checkbox
    id="agree"
    name="agree"
    label="I agree to the terms"
    required
  />
</form>`}
                language="astro"
                filename="example.astro"
            />
        </section>
	</main>
	</div>
</Layout>