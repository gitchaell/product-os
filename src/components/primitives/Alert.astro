---
import { tv, type VariantProps } from 'tailwind-variants';
import Icon from './Icon.astro';

const alertVariants = tv({
	base: 'flex items-start gap-3 rounded-lg border p-4 shadow-sm',
	variants: {
		variant: {
			info: 'border-blue-200 bg-blue-50 text-blue-800 dark:border-blue-900/50 dark:bg-blue-950/30 dark:text-blue-300',
			success:
				'border-green-200 bg-green-50 text-green-800 dark:border-green-900/50 dark:bg-green-950/30 dark:text-green-300',
			warning:
				'border-yellow-200 bg-yellow-50 text-yellow-800 dark:border-yellow-900/50 dark:bg-yellow-950/30 dark:text-yellow-300',
			error:
				'border-red-200 bg-red-50 text-red-800 dark:border-red-900/50 dark:bg-red-950/30 dark:text-red-300',
		},
	},
	defaultVariants: {
		variant: 'info',
	},
});

interface Props extends VariantProps<typeof alertVariants> {
	class?: string;
	title?: string;
	icon?: string;
}

const { class: className, variant, title, icon, ...rest } = Astro.props;

// Map variants to default icons if none provided
const defaultIcons = {
	info: 'info',
	success: 'check-circle',
	warning: 'triangle-alert',
	error: 'circle-x',
};

const iconName = icon || defaultIcons[variant || 'info'];
---

<div class={alertVariants({ variant, class: className })} role="alert" {...rest}>
	<Icon name={iconName} class="mt-0.5 shrink-0 h-5 w-5" />
	<div class="flex-1">
		{title && <h4 class="mb-1 font-semibold">{title}</h4>}
		<div class="text-sm opacity-90">
			<slot />
		</div>
	</div>
</div>
