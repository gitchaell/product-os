---
import { ArrowRight, Github } from '@lucide/astro';
import Icon from "../primitives/Icon.astro";
import { defaultLang } from '@/i18n/ui';
import { type LangCode, useTranslations } from '@/i18n/utils';

interface Props {
	lang?: LangCode;
}

const { lang = defaultLang } = Astro.props;

const t = useTranslations(lang);
---

<section
	class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center overflow-hidden py-20 md:py-32"
>
	<!-- Background grid & gradients -->
	<div
		class="absolute inset-0 z-0 flex items-center justify-center pointer-events-none"
	>
		<div
			class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-size-[24px_24px] mask-[radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"
		>
		</div>
		<div
			class="absolute top-0 w-full h-full bg-zinc-50/10 dark:bg-zinc-950/10 backdrop-blur-[1px]"
		>
		</div>
		<div
			class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2 w-200 h-100 bg-linear-to-b from-black/10 to-transparent dark:from-white/10 blur-3xl rounded-full opacity-50"
		>
		</div>
	</div>

	<div
		class="relative z-10 flex w-full max-w-5xl flex-col items-center gap-8 px-6 text-center"
	>
		<!-- Pill badge -->
		<a
			href="https://github.com/gitchaell/astro-template"
			target="_blank"
			rel="noopener noreferrer"
			class="group flex items-center gap-2 rounded-full border border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5 px-4 py-1.5 text-sm font-medium text-zinc-800 dark:text-zinc-200 backdrop-blur-md transition-colors hover:bg-black/10 dark:hover:bg-white/10"
		>
			<span class="relative flex h-2 w-2">
				<span
					class="absolute inline-flex h-full w-full animate-ping rounded-full bg-zinc-900 dark:bg-zinc-100 opacity-75"
				></span>
				<span
					class="relative inline-flex h-2 w-2 rounded-full bg-zinc-900 dark:bg-zinc-100"
				></span>
			</span>
			v1.0 is now live
			<ArrowRight
				class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
			/>
		</a>

		<!-- Typography -->
		<div class="flex flex-col gap-6">
			<h1
				class="text-balance text-6xl font-black tracking-tighter text-zinc-900 dark:text-white sm:text-7xl lg:text-8xl"
			>
				{t("hero.title")}
			</h1>
			<p
				class="mx-auto max-w-2xl text-balance text-lg text-zinc-600 dark:text-zinc-400 sm:text-xl leading-relaxed"
			>
				{t("hero.subtitle")}
			</p>
		</div>

		<!-- CTAs -->
		<div
			class="flex flex-col sm:flex-row items-center gap-4 mt-4 w-full sm:w-auto"
		>
			<a
				href={`/${lang}/login`}
				class="group flex h-12 w-full sm:w-auto items-center justify-center gap-2 rounded-full bg-zinc-900 px-8 text-sm font-medium text-white transition-all hover:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200 dark:focus:ring-white dark:focus:ring-offset-zinc-950"
			>
				Get Started
				<ArrowRight
					class="h-4 w-4 transition-transform group-hover:translate-x-1"
				/>
			</a>
			<a
				href="https://github.com/gitchaell/astro-template"
				target="_blank"
				rel="noopener noreferrer"
				class="group flex h-12 w-full sm:w-auto items-center justify-center gap-2 rounded-full border border-zinc-200 bg-white px-8 text-sm font-medium text-zinc-900 transition-all hover:bg-zinc-50 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-900 dark:focus:ring-white dark:focus:ring-offset-zinc-950"
			>
				<Github class="h-4 w-4" />
				View Source
			</a>
		</div>

		<!-- Features/Tech Stack -->
		<div
			class="mt-16 w-full pt-8 border-t border-zinc-200 dark:border-zinc-800"
		>
			<p
				class="text-sm font-medium text-zinc-500 dark:text-zinc-400 mb-6 uppercase tracking-widest"
			>
				Powered By
			</p>
			<div
					class="flex flex-wrap justify-center gap-6 md:gap-12 transition-all"
			>
					<div class="flex items-center gap-2 transition-all cursor-pointer hover:scale-105">
						<Icon name="astro.svg" class="h-8 w-8" />
						<span class="text-xl font-bold text-zinc-800 dark:text-zinc-200">Astro</span>
					</div>
					<div class="flex items-center gap-2 transition-all cursor-pointer hover:scale-105">
						<Icon name="react.svg" class="h-8 w-8" />
						<span class="text-xl font-bold text-zinc-800 dark:text-zinc-200">React</span>
					</div>
					<div class="flex items-center gap-2 transition-all cursor-pointer hover:scale-105">
						<Icon name="tailwindcss.svg" class="h-8 w-8" />
						<span class="text-xl font-bold text-zinc-800 dark:text-zinc-200"
							>Tailwind v4</span
						>
					</div>
					<div class="flex items-center gap-2 transition-all cursor-pointer hover:scale-105">
						<Icon name="typescript.svg" class="h-8 w-8 rounded-sm" />
						<span class="text-xl font-bold text-zinc-800 dark:text-zinc-200"
							>TypeScript</span
						>
					</div>
					<div class="flex items-center gap-2 transition-all cursor-pointer hover:scale-105">
						<Icon name="biomejs.svg" class="h-8 w-8" />
						<span class="text-xl font-bold text-zinc-800 dark:text-zinc-200">Biome</span>
					</div>
					<div class="flex items-center gap-2 transition-all cursor-pointer hover:scale-105">
						<Icon name="vercel.svg" class="h-8 w-8 dark:invert" />
						<span class="text-xl font-bold text-zinc-800 dark:text-zinc-200">Vercel</span>
					</div>
					<div class="flex items-center gap-2 transition-all cursor-pointer hover:scale-105">
						<Icon name="node.svg" class="h-8 w-8" />
						<span class="text-xl font-bold text-zinc-800 dark:text-zinc-200">Node</span>
					</div>
			</div>
		</div>
	</div>
</section>
