---
import { tv, type VariantProps } from 'tailwind-variants';
import Icon from './Icon.astro';

const tabVariants = tv({
	base: 'inline-flex items-center justify-center font-medium transition-all focus-visible:outline-none disabled:pointer-events-none disabled:opacity-50 cursor-pointer',
	variants: {
		variant: {
			text: 'h-10 px-4 border-b-2 gap-2 text-sm',
			icon: 'flex-col gap-1 py-2 px-4 text-xs',
			selector: 'h-10 px-6 rounded-md text-sm',
		},
		active: {
			true: '',
			false: '',
		},
	},
	compoundVariants: [
		{
			variant: 'text',
			active: true,
			class:
				'border-[#101828] text-[#101828] dark:border-white dark:text-white',
		},
		{
			variant: 'text',
			active: false,
			class:
				'border-transparent text-[#475467] hover:text-[#101828] hover:border-[#D0D5DD] dark:text-[#98A2B3] dark:hover:text-white dark:hover:border-[#475467]',
		},
		{
			variant: 'icon',
			active: true,
			class: 'text-[#101828] font-bold dark:text-white',
		},
		{
			variant: 'icon',
			active: false,
			class:
				'text-[#98A2B3] font-medium hover:text-[#475467] dark:text-[#475467] dark:hover:text-[#98A2B3]',
		},
		{
			variant: 'selector',
			active: true,
			class:
				'bg-white text-[#101828] shadow-sm dark:bg-[#1D2939] dark:text-white',
		},
		{
			variant: 'selector',
			active: false,
			class:
				'text-[#475467] hover:text-[#101828] hover:bg-[#F9FAFB]/50 dark:text-[#98A2B3] dark:hover:text-white dark:hover:bg-[#101828]/50',
		},
	],
	defaultVariants: {
		variant: 'text',
		active: false,
	},
});

interface Props extends VariantProps<typeof tabVariants> {
	class?: string;
	label: string;
	iconLeft?: string;
	iconRight?: string;
	icon?: string; // For icon variant
	id?: string;
	controls?: string;
}

const {
	class: className,
	variant = 'text',
	active = false,
	label,
	iconLeft,
	iconRight,
	icon,
	id,
	controls,
} = Astro.props;

// Default ID for accessibility
const tabId = id || `tab-${Math.random().toString(36).substring(2, 9)}`;
---

<button
	type="button"
	role="tab"
	id={tabId}
	aria-selected={active}
	aria-controls={controls}
	tabindex={active ? 0 : -1}
	class={tabVariants({ variant, active, class: className })}
>
	{variant === 'text' && (
		<>
			{iconLeft && <Icon name={iconLeft} class="h-4 w-4" />}
			<span>{label}</span>
			{iconRight && <Icon name={iconRight} class="h-4 w-4" />}
		</>
	)}

	{variant === 'icon' && (
		<>
			{(icon || iconLeft) && <Icon name={(icon || iconLeft) as string} class="h-6 w-6" />}
			<span>{label}</span>
		</>
	)}

	{variant === 'selector' && (
		<span>{label}</span>
	)}
</button>
