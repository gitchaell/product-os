---
// FeedbackForm.astro
import { Icon } from 'astro-icon/components';
---

<div class="bg-white/90 dark:bg-[#102222]/80 dark:backdrop-blur-md rounded-xl overflow-hidden shadow-xl dark:shadow-2xl grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-slate-200 dark:divide-slate-800 border border-slate-200 dark:border-white/5 transition-colors duration-300">

  <!-- Left Side: Submit a Suggestion -->
  <div class="p-8 lg:p-12 bg-white dark:bg-transparent transition-colors duration-300">
    <div class="flex items-center gap-3 mb-8">
      <Icon name="tabler:bulb" class="w-6 h-6 text-teal-600 dark:text-primary" />
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white font-display">Submit a Suggestion</h2>
    </div>

    <!-- CloudCannon Form Handling - uses native standard form element -->
    <!-- The action can be left blank or pointed to a success page, but CloudCannon automatically captures it by name -->
    <form action="/success" method="POST" class="space-y-6">
      <!-- Implicitly identify this form to CloudCannon -->
      <input type="hidden" name="form-name" value="suggestion" />

      <div class="group">
        <label class="block text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider mb-2" for="suggestion_title">Feature Name</label>
        <input
          id="suggestion_title"
          name="title"
          type="text"
          required
          class="w-full bg-white dark:bg-slate-900/50 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-200 focus:outline-none focus:border-teal-500 dark:focus:border-primary focus:ring-1 focus:ring-teal-500 dark:focus:ring-primary transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600 shadow-sm dark:shadow-inner"
          placeholder="What's your big idea?"
        />
      </div>

      <div class="group">
        <label class="block text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider mb-2" for="suggestion_category">Category</label>
        <div class="relative">
          <select
            id="suggestion_category"
            name="category"
            required
            class="w-full bg-white dark:bg-slate-900/50 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-200 focus:outline-none focus:border-teal-500 dark:focus:border-primary focus:ring-1 focus:ring-teal-500 dark:focus:ring-primary appearance-none cursor-pointer transition-all shadow-sm dark:shadow-inner"
          >
            <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="UI/UX Improvements">UI/UX Improvements</option>
            <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="New Functionality">New Functionality</option>
            <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="Performance">Performance</option>
            <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="Integration">Integration</option>
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-500 dark:text-slate-400">
            <Icon name="tabler:chevron-down" class="w-4 h-4" />
          </div>
        </div>
      </div>

      <div class="group">
        <label class="block text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider mb-2" for="suggestion_description">Description</label>
        <textarea
          id="suggestion_description"
          name="description"
          required
          rows="4"
          class="w-full bg-white dark:bg-slate-900/50 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-200 focus:outline-none focus:border-teal-500 dark:focus:border-primary focus:ring-1 focus:ring-teal-500 dark:focus:ring-primary transition-all resize-none placeholder:text-slate-400 dark:placeholder:text-slate-600 shadow-sm dark:shadow-inner"
          placeholder="How would this improve your workflow?"
        ></textarea>
      </div>

      <button type="submit" class="w-full bg-gradient-to-r from-teal-500 dark:from-primary to-teal-600 dark:to-primary/80 hover:from-teal-600 dark:hover:from-primary hover:to-teal-700 dark:hover:to-primary text-white dark:text-background-dark font-bold py-3 px-6 rounded-lg transition-all flex items-center justify-center gap-2 group shadow-md dark:shadow-[0_0_15px_rgba(13,242,242,0.3)] hover:shadow-lg dark:hover:shadow-[0_0_25px_rgba(13,242,242,0.5)] transform hover:-translate-y-0.5">
        <span>Submit Suggestion</span>
        <Icon name="tabler:send" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
      </button>
    </form>
  </div>

  <!-- Right Side: Report an Issue -->
  <div class="p-8 lg:p-12 bg-slate-50 dark:bg-white/[0.02] transition-colors duration-300">
    <div class="flex items-center gap-3 mb-8">
      <Icon name="tabler:bug" class="w-6 h-6 text-red-500 dark:text-red-400" />
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white font-display">Report an Issue</h2>
    </div>

    <!-- Second CloudCannon Form Handling for Issue reporting -->
    <!-- enctype="multipart/form-data" is required for file uploads natively -->
    <form action="/success" method="POST" enctype="multipart/form-data" class="space-y-6">
      <input type="hidden" name="form-name" value="bug_report" />

      <div class="group">
        <label class="block text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider mb-2" for="issue_title">Issue Title</label>
        <input
          id="issue_title"
          name="title"
          type="text"
          required
          class="w-full bg-white dark:bg-slate-900/50 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-200 focus:outline-none focus:border-red-500 dark:focus:border-red-400 focus:ring-1 focus:ring-red-500 dark:focus:ring-red-400 transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600 shadow-sm dark:shadow-inner"
          placeholder="Describe the problem briefly"
        />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="group">
          <label class="block text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider mb-2" for="issue_severity">Severity</label>
          <div class="relative">
            <select
              id="issue_severity"
              name="severity"
              required
              class="w-full bg-white dark:bg-slate-900/50 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-200 focus:outline-none focus:border-red-500 dark:focus:border-red-400 focus:ring-1 focus:ring-red-500 dark:focus:ring-red-400 appearance-none cursor-pointer transition-all shadow-sm dark:shadow-inner"
            >
              <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="Low">Low</option>
              <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="Medium">Medium</option>
              <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="High">High</option>
              <option class="bg-white dark:bg-slate-800 text-red-600 dark:text-red-400 font-bold" value="Critical">Critical</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-500 dark:text-slate-400">
              <Icon name="tabler:chevron-down" class="w-4 h-4" />
            </div>
          </div>
        </div>
        <div class="group">
          <label class="block text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider mb-2" for="issue_browser">Browser</label>
          <div class="relative">
            <select
              id="issue_browser"
              name="browser"
              class="w-full bg-white dark:bg-slate-900/50 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-200 focus:outline-none focus:border-red-500 dark:focus:border-red-400 focus:ring-1 focus:ring-red-500 dark:focus:ring-red-400 appearance-none cursor-pointer transition-all shadow-sm dark:shadow-inner"
            >
              <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="Chrome">Chrome</option>
              <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="Safari">Safari</option>
              <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="Firefox">Firefox</option>
              <option class="bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-200" value="Edge">Edge</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-500 dark:text-slate-400">
              <Icon name="tabler:chevron-down" class="w-4 h-4" />
            </div>
          </div>
        </div>
      </div>

      <div class="group relative">
        <label class="block text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider mb-2" for="issue_attachment">Attach Evidence</label>
        <div class="border-2 border-dashed border-slate-300 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/30 rounded-xl p-8 flex flex-col items-center justify-center gap-2 hover:border-red-300 dark:hover:border-red-400/50 hover:bg-slate-100 dark:hover:bg-slate-900/50 transition-colors cursor-pointer group/upload relative">
          <Icon name="tabler:cloud-upload" class="w-10 h-10 text-slate-400 dark:text-slate-600 group-hover/upload:text-red-500 dark:group-hover/upload:text-red-400 transition-colors" />
          <p class="text-sm text-slate-500 dark:text-slate-400">Drop screenshots or <span class="text-red-500 dark:text-red-400">browse</span></p>
          <p class="text-[10px] text-slate-400 dark:text-slate-600 uppercase tracking-tighter">PNG, JPG up to 10MB</p>
          <input
            id="issue_attachment"
            type="file"
            name="attachment"
            accept="image/png, image/jpeg"
            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
          />
        </div>
      </div>

      <button type="submit" class="w-full bg-white dark:bg-transparent border-2 border-slate-300 dark:border-slate-700 hover:border-red-500 dark:hover:border-red-400 hover:bg-red-50 dark:hover:bg-transparent text-slate-600 dark:text-slate-300 hover:text-red-600 dark:hover:text-red-400 font-bold py-3 px-6 rounded-lg transition-all flex items-center justify-center gap-2 group transform hover:-translate-y-0.5">
        <Icon name="tabler:bug" class="w-5 h-5 group-hover:animate-pulse" />
        <span>Report Bug</span>
      </button>
    </form>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    // Add an event listener to all forms on the page
    document.querySelectorAll('form').forEach(form => {
      form.addEventListener('submit', (e) => {
        e.preventDefault(); // Prevent the default form submission

        const formName = form.querySelector('input[name="form-name"]')?.getAttribute('value');

        if (formName === 'suggestion') {
          alert('Thank you! Your suggestion has been successfully submitted.');
        } else if (formName === 'bug_report') {
          alert('Thank you! Your issue report has been successfully submitted.');
        } else {
          alert('Form submitted successfully.');
        }

        form.reset(); // Reset the form fields
      });
    });
  });
</script>
