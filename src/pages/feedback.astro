---
import FeedbackForm from '../components/FeedbackForm.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Feedback | Product OS Hub">
  <div class="flex-1 flex flex-col items-center justify-center p-6 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-primary/5 via-transparent to-transparent mt-12">
    <div class="w-full max-w-5xl">
      <!-- Header Section -->
      <div class="mb-10 text-center">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white mb-3">Feedback Center</h1>
        <p class="text-slate-500 dark:text-slate-400 text-lg">Help us shape the future of Product OS.</p>
      </div>

      <FeedbackForm />
    </div>
  </div>
</Layout>
