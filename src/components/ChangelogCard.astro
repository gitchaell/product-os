---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'changelog'>;
}

const { entry } = Astro.props;
const { data } = entry;
const { title, description, version, date, type, banner_image } = data;

// Format the date for display
const formattedDate = new Date(date).toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<!-- Changelog Card Display -->
<div class="relative pl-12 md:pl-24 group">
  <!-- Timeline Indicator -->
  <div class="absolute left-4 md:left-8 top-2 -translate-x-1/2 w-4 h-4 rounded-full bg-slate-400 dark:bg-slate-800 z-10 border-4 border-white dark:border-background-dark group-hover:bg-primary transition-colors"></div>

  <div class="flex flex-col gap-6">
    <div class="flex items-center gap-4">
      <span class="text-slate-500 font-mono text-sm font-bold tracking-widest uppercase">{version}</span>
      <span class="text-slate-500 text-sm hidden sm:inline">&bull;</span>
      <span class="text-slate-500 text-sm font-medium">{formattedDate}</span>
    </div>

    <div class="grid grid-cols-1 gap-6">
      <a href={`/changelog/${entry.id}`} class="block bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-8 group hover:border-primary/50 dark:hover:border-primary/50 transition-all hover:bg-slate-50/50 dark:hover:bg-slate-800/50 cursor-pointer text-inherit no-underline shadow-sm dark:shadow-none glass">
        <div class="flex gap-2 mb-4">
          <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border border-primary/20">
            {type}
          </span>
        </div>

        <h3 class="text-xl font-bold mb-4">
          {title}
        </h3>

        <div class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-6 prose prose-sm dark:prose-invert">
          {description}
        </div>

        {banner_image && (
          <div class="rounded-lg overflow-hidden border border-slate-200 dark:border-border-dark bg-slate-100 dark:bg-neutral-dark aspect-video flex items-center justify-center relative">
            <img
              src={banner_image}
              alt={title}
              class="object-cover w-full h-full"
            />
          </div>
        )}
      </a>
    </div>
  </div>
</div>

<style>
  .glass {
    backdrop-filter: blur(12px);
  }
</style>
