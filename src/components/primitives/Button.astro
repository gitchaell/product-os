---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

const buttonVariants = tv({
	base: 'inline-flex items-center justify-center gap-2 font-medium transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-zinc-950 cursor-pointer disabled:pointer-events-none',
	variants: {
		variant: {
			primary:
				'bg-zinc-900 text-white hover:bg-zinc-800 focus:ring-zinc-900 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200 dark:focus:ring-white disabled:bg-zinc-400 disabled:text-white dark:disabled:bg-zinc-700 dark:disabled:text-zinc-400',
			secondary:
				'bg-zinc-100 text-zinc-900 hover:bg-zinc-200 focus:ring-zinc-200 dark:bg-zinc-800 dark:text-white dark:hover:bg-zinc-700 dark:focus:ring-zinc-800 disabled:bg-zinc-100 disabled:text-zinc-400 dark:disabled:bg-zinc-800 dark:disabled:text-zinc-500',
			outline:
				'border border-zinc-200 bg-transparent text-zinc-900 hover:bg-zinc-50 focus:ring-zinc-200 dark:border-zinc-800 dark:text-white dark:hover:bg-zinc-900 dark:focus:ring-zinc-800 disabled:border-zinc-200 disabled:text-zinc-400 dark:disabled:border-zinc-800 dark:disabled:text-zinc-500',
			ghost:
				'bg-transparent text-zinc-900 hover:bg-zinc-100 focus:ring-zinc-200 dark:text-white dark:hover:bg-zinc-800 dark:focus:ring-zinc-800',
		},
		size: {
			sm: 'h-9 px-4 text-xs',
			md: 'h-11 px-6 text-sm',
			lg: 'h-12 px-8 text-base',
		},
		pill: {
			true: 'rounded-full',
			false: 'rounded-md',
		},
	},
	defaultVariants: {
		variant: 'primary',
		size: 'md',
		pill: false,
	},
});

type ButtonVariants = VariantProps<typeof buttonVariants>;

interface Props extends HTMLAttributes<'button'>, ButtonVariants {
	action?: string;
	method?: 'get' | 'post' | 'put' | 'delete';
	target?: string;
	swap?: 'inner' | 'outer' | 'prepend' | 'append';
}

const {
	variant,
	size,
	pill,
	action,
	method = 'get',
	target,
	swap = 'inner',
	class: className,
	...rest
} = Astro.props;

// Set up custom action attributes if 'action' is provided
const actionProps = action
	? {
			'data-action': action,
			'data-method': method,
			'data-target': target,
			'data-swap': swap,
		}
	: {};
---

<button
	class={buttonVariants({ variant, size, pill, class: className })}
	{...actionProps}
	{...rest}
>
	<slot />
</button>
