---
import { tv } from 'tailwind-variants';
import Icon from './Icon.astro';

const accordionVariants = tv({
	base: 'w-full divide-y divide-zinc-200 dark:divide-zinc-800 border-y border-zinc-200 dark:border-zinc-800',
});

interface AccordionItem {
	title: string;
	content: string;
	isOpen?: boolean;
}

interface Props {
	class?: string;
	items: AccordionItem[];
}

const { class: className, items } = Astro.props;
---

<div class={accordionVariants({ class: className })} data-accordion>
	{
		items.map((item) => {
			const itemId = `accordion-item-${Math.random().toString(36).substring(2, 9)}`;
			return (
				<div class="py-2" data-accordion-item>
					<button
						type="button"
						class="flex w-full items-center justify-between py-2 text-left text-sm font-medium text-zinc-900 transition-colors hover:text-zinc-600 dark:text-zinc-100 dark:hover:text-zinc-400 focus:outline-none"
						aria-expanded={item.isOpen ? 'true' : 'false'}
						aria-controls={itemId}
						data-accordion-trigger
					>
						{item.title}
						<Icon
							name="ChevronDown"
							class={`h-4 w-4 shrink-0 text-zinc-500 transition-transform duration-200 ${item.isOpen ? 'rotate-180' : ''}`}
							data-accordion-icon
						/>
					</button>
					<div
						id={itemId}
						class={`grid transition-all duration-200 ease-in-out ${item.isOpen ? 'grid-rows-[1fr] opacity-100' : 'grid-rows-[0fr] opacity-0'}`}
					>
						<div class="overflow-hidden">
							<div class="pb-4 pt-1 text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
								{item.content}
							</div>
						</div>
					</div>
				</div>
			);
		})
	}
</div>

<script>
	const initAccordions = () => {
		document.querySelectorAll('[data-accordion]').forEach((accordion) => {
			const triggers = accordion.querySelectorAll('[data-accordion-trigger]');

			triggers.forEach((trigger) => {
				// Avoid attaching multiple listeners if re-initialized
				const clone = trigger.cloneNode(true) as HTMLElement;
				trigger.parentNode?.replaceChild(clone, trigger);

				clone.addEventListener('click', () => {
					const isExpanded = clone.getAttribute('aria-expanded') === 'true';
					const icon = clone.querySelector('[data-accordion-icon]');
					const contentId = clone.getAttribute('aria-controls');
					const content = document.getElementById(contentId || '');

					if (isExpanded) {
						clone.setAttribute('aria-expanded', 'false');
						icon?.classList.remove('rotate-180');
						if (content) {
							content.classList.remove('grid-rows-[1fr]', 'opacity-100');
							content.classList.add('grid-rows-[0fr]', 'opacity-0');
						}
					} else {
						clone.setAttribute('aria-expanded', 'true');
						icon?.classList.add('rotate-180');
						if (content) {
							content.classList.remove('grid-rows-[0fr]', 'opacity-0');
							content.classList.add('grid-rows-[1fr]', 'opacity-100');
						}
					}
				});
			});
		});
	};

	document.addEventListener('astro:page-load', initAccordions);
</script>
