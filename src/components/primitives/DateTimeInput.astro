---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import Icon from './Icon.astro';

const dateTimeInputVariants = tv({
	base: 'flex h-11 w-full rounded-md border border-zinc-200 bg-white px-3 py-2 text-sm text-zinc-900 transition-colors placeholder:text-zinc-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-zinc-900 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 dark:placeholder:text-zinc-400 dark:focus-visible:ring-zinc-100 dark:focus-visible:ring-offset-zinc-950 cursor-pointer text-left',
});

type DateTimeInputVariants = VariantProps<typeof dateTimeInputVariants>;

interface Props extends HTMLAttributes<'input'>, DateTimeInputVariants {
	label?: string;
	error?: string;
	placeholder?: string;
}

const {
	type = 'date',
	label,
	error,
	class: className,
	id,
	placeholder = 'Select...',
	...rest
} = Astro.props;

// Ensure we have an ID for label association
const inputId = id || `datetime-${Math.random().toString(36).substring(2, 9)}`;
const isTime = type === 'time';
const popoverId = `popover-${inputId}`;
---

<div class="space-y-1.5 w-full relative" data-datetime-picker={inputId} data-type={type}>
	{label && (
		<label for={inputId} class="block text-sm font-medium text-zinc-900 dark:text-zinc-100">
			{label}
		</label>
	)}

	<input type="hidden" id={inputId} name={rest.name} />

	<button
		type="button"
		class={dateTimeInputVariants({ class: [className, 'pr-10 relative'] })}
		data-datetime-trigger
	>
		<span data-datetime-display class="text-zinc-500 dark:text-zinc-400">{placeholder}</span>
		<div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-zinc-500 dark:text-zinc-400">
			{isTime ? (
				<Icon name="Clock" class="h-5 w-5" />
			) : (
				<Icon name="Calendar" class="h-5 w-5" />
			)}
		</div>
	</button>

	<!-- Custom Dropdown Popover -->
	<div
		id={popoverId}
		class="absolute z-50 mt-1 hidden w-full min-w-[280px] overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-lg dark:border-zinc-800 dark:bg-zinc-950 p-3"
		data-datetime-popover
	>
		{!isTime ? (
			<div class="space-y-3">
				<div class="flex items-center justify-between">
					<button type="button" class="p-1 hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded text-zinc-900 dark:text-white" data-cal-prev>
						<Icon name="ChevronLeft" class="w-4 h-4" />
					</button>
					<span class="text-sm font-medium text-zinc-900 dark:text-white" data-cal-month>October 2024</span>
					<button type="button" class="p-1 hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded text-zinc-900 dark:text-white" data-cal-next>
						<Icon name="ChevronRight" class="w-4 h-4" />
					</button>
				</div>
				<div class="grid grid-cols-7 gap-1 text-center text-xs font-medium text-zinc-500 dark:text-zinc-400">
					<div>Su</div><div>Mo</div><div>Tu</div><div>We</div><div>Th</div><div>Fr</div><div>Sa</div>
				</div>
				<div class="grid grid-cols-7 gap-1" data-cal-grid>
					<!-- Generated by JS -->
				</div>
			</div>
		) : (
			<div class="flex gap-2 justify-center">
				<div class="flex flex-col gap-1 items-center">
					<span class="text-xs text-zinc-500 dark:text-zinc-400">Hour</span>
					<div class="h-48 overflow-y-auto pr-1 w-16 scrollbar-hide text-center space-y-1" data-time-hours>
						<!-- Generated by JS -->
					</div>
				</div>
				<span class="text-xl font-bold mt-4">:</span>
				<div class="flex flex-col gap-1 items-center">
					<span class="text-xs text-zinc-500 dark:text-zinc-400">Minute</span>
					<div class="h-48 overflow-y-auto pr-1 w-16 scrollbar-hide text-center space-y-1" data-time-minutes>
						<!-- Generated by JS -->
					</div>
				</div>
			</div>
		)}
	</div>

	{error && (
		<p class="text-sm text-red-500 dark:text-red-400">
			{error}
		</p>
	)}
</div>

<script>
	const initDateTimePickers = () => {
		document.querySelectorAll('[data-datetime-picker]').forEach(container => {
			const type = container.getAttribute('data-type');
			const trigger = container.querySelector('[data-datetime-trigger]');
			const popover = container.querySelector('[data-datetime-popover]');
			const display = container.querySelector('[data-datetime-display]');
			const hiddenInput = container.querySelector('input[type="hidden"]') as HTMLInputElement;

			if (!trigger || !popover) return;

			trigger.addEventListener('click', (e) => {
				e.preventDefault();
				e.stopPropagation();

				// Close others
				document.querySelectorAll('[data-datetime-popover]').forEach(p => {
					if (p !== popover) p.classList.add('hidden');
				});

				popover.classList.toggle('hidden');
			});

			if (type === 'date') {
				const grid = container.querySelector('[data-cal-grid]');
				const monthLabel = container.querySelector('[data-cal-month]');
				const prevBtn = container.querySelector('[data-cal-prev]');
				const nextBtn = container.querySelector('[data-cal-next]');

				let currentDate = new Date();

				const renderCalendar = () => {
					if (!grid || !monthLabel) return;
					grid.innerHTML = '';

					const year = currentDate.getFullYear();
					const month = currentDate.getMonth();

					monthLabel.textContent = new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric' }).format(currentDate);

					const firstDay = new Date(year, month, 1).getDay();
					const daysInMonth = new Date(year, month + 1, 0).getDate();

					for (let i = 0; i < firstDay; i++) {
						grid.appendChild(document.createElement('div'));
					}

					for (let d = 1; d <= daysInMonth; d++) {
						const btn = document.createElement('button');
						btn.type = 'button';
						btn.className = 'w-8 h-8 rounded-full text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800 text-zinc-900 dark:text-zinc-100 flex items-center justify-center';
						btn.textContent = d.toString();

						btn.addEventListener('click', (e) => {
							e.stopPropagation();
							const selectedDate = new Date(year, month, d);
							const formatted = selectedDate.toISOString().split('T')[0];
							if (hiddenInput) hiddenInput.value = formatted;
							if (display) {
								display.textContent = new Intl.DateTimeFormat('en-US', { dateStyle: 'medium' }).format(selectedDate);
								display.classList.remove('text-zinc-500', 'dark:text-zinc-400');
								display.classList.add('text-zinc-900', 'dark:text-zinc-100');
							}
							popover.classList.add('hidden');
						});
						grid.appendChild(btn);
					}
				};

				renderCalendar();

				prevBtn?.addEventListener('click', (e) => {
					e.stopPropagation();
					currentDate.setMonth(currentDate.getMonth() - 1);
					renderCalendar();
				});

				nextBtn?.addEventListener('click', (e) => {
					e.stopPropagation();
					currentDate.setMonth(currentDate.getMonth() + 1);
					renderCalendar();
				});

			} else if (type === 'time') {
				const hoursContainer = container.querySelector('[data-time-hours]');
				const minutesContainer = container.querySelector('[data-time-minutes]');
				let h = '12', m = '00';

				const updateTime = () => {
					const formatted = `${h}:${m}`;
					if (hiddenInput) hiddenInput.value = formatted;
					if (display) {
						display.textContent = formatted;
						display.classList.remove('text-zinc-500', 'dark:text-zinc-400');
						display.classList.add('text-zinc-900', 'dark:text-zinc-100');
					}
				};

				if (hoursContainer && minutesContainer) {
					for (let i = 0; i < 24; i++) {
						const val = i.toString().padStart(2, '0');
						const btn = document.createElement('button');
						btn.type = 'button';
						btn.className = 'w-full py-2 rounded text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800 text-zinc-900 dark:text-zinc-100';
						btn.textContent = val;
						btn.addEventListener('click', (e) => {
							e.stopPropagation();
							h = val;
							updateTime();
						});
						hoursContainer.appendChild(btn);
					}

					for (let i = 0; i < 60; i += 5) {
						const val = i.toString().padStart(2, '0');
						const btn = document.createElement('button');
						btn.type = 'button';
						btn.className = 'w-full py-2 rounded text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800 text-zinc-900 dark:text-zinc-100';
						btn.textContent = val;
						btn.addEventListener('click', (e) => {
							e.stopPropagation();
							m = val;
							updateTime();
							popover.classList.add('hidden');
						});
						minutesContainer.appendChild(btn);
					}
				}
			}
		});

		document.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			if (!target.closest('[data-datetime-picker]')) {
				document.querySelectorAll('[data-datetime-popover]').forEach(p => p.classList.add('hidden'));
			}
		});
	};

	document.addEventListener('astro:page-load', initDateTimePickers);
</script>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
