---
import { tv, type VariantProps } from 'tailwind-variants';
import Icon from './Icon.astro';

const searchInputVariants = tv({
	base: 'flex h-11 w-full rounded-md border border-[#101828] bg-white px-3 py-2 text-sm text-[#101828] transition-colors placeholder:text-[#98A2B3] focus:outline-none focus:ring-2 focus:ring-[#101828] focus:ring-offset-2 disabled:cursor-not-allowed disabled:bg-[#F2F4F7] disabled:text-[#98A2B3] disabled:border-[#D0D5DD] dark:border-white dark:bg-[#1D2939] dark:text-white dark:placeholder:text-[#475467] dark:focus:ring-white dark:disabled:bg-[#344054] dark:disabled:text-[#475467] dark:disabled:border-[#344054]',
});

interface Props
	extends astroHTML.JSX.InputHTMLAttributes,
		VariantProps<typeof searchInputVariants> {
	label?: string;
	error?: string;
}

const {
	label = 'Search',
	error,
	class: className,
	id,
	placeholder = 'Enter search terms',
	...rest
} = Astro.props;

// Ensure we have an ID for label association
const inputId = id || `search-${Math.random().toString(36).substring(2, 9)}`;
---

<div class="space-y-1 w-full">
	{label && (
		<label for={inputId} class="block text-sm font-medium text-[#344054] dark:text-[#E4E7EC]">
			{label}
		</label>
	)}

	<div class="relative">
		<input
			type="search"
			id={inputId}
			class={searchInputVariants({ class: ['pr-10', className] })}
			placeholder={placeholder}
			{...rest}
		/>
		<div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
			<Icon name="Search" class="h-5 w-5 text-[#101828] dark:text-white" />
		</div>
	</div>

	{error && (
		<p class="text-sm text-red-500 dark:text-red-400">
			{error}
		</p>
	)}
</div>
